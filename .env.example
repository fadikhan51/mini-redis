NODE_ENV=development
APP_NAME=mini-redis
HTTP_HOST=0.0.0.0
HTTP_PORT=8080
REDIS_HOST=0.0.0.0
REDIS_PORT=6379
REDIS_PASSWORD=
ADMIN_TOKEN=
LOG_LEVEL=info

# Cache configuration
CACHE_MAX_KEYS=100000
CACHE_MAX_MEMORY_BYTES=134217728
CACHE_DEFAULT_TTL_MS=0
CACHE_SWEEP_INTERVAL_MS=1000
CACHE_EVICTION_POLICY=lru

# Limits
MAX_KEY_BYTES=512
MAX_VALUE_BYTES=1048576
MAX_COMMAND_BYTES=2097152

# Observability
HEARTBEAT_INTERVAL_MS=30000

# MiniStack integration
MINISTACK_ENABLED=false
MINISTACK_ENDPOINT=http://localhost:4566
MINISTACK_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
MINISTACK_ELASTICACHE_CLUSTER_ID=mini-redis-reference
MINISTACK_ELASTICACHE_BASE_PORT=16379
