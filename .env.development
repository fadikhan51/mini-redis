# .env.development
# Application config
NODE_ENV=development
APP_NAME=mini-redis

# HTTP Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8081

# Redis TCP Server
REDIS_HOST=0.0.0.0
REDIS_PORT=6479

# Logging
LOG_LEVEL=debug

# Cache limits
CACHE_MAX_KEYS=100000
CACHE_MAX_MEMORY_BYTES=134217728
CACHE_DEFAULT_TTL_MS=0
CACHE_SWEEP_INTERVAL_MS=1000
CACHE_EVICTION_POLICY=lru

# Cluster Config (Disabled for single node dev by default)
# CLUSTER_ENABLED=false
