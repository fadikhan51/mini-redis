{
  "name": "mini-redis",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:integration": "vitest run --dir tests/integration",
    "test:ministack": "vitest run --dir tests/ministack",
    "test:e2e": "vitest run --dir tests/e2e",
    "docker:up": "docker compose -f docker/compose/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/compose/docker-compose.yml down",
    "docker:cluster:up": "docker compose -f docker/compose/docker-compose.cluster.yml up --build",
    "docker:cluster:down": "docker compose -f docker/compose/docker-compose.cluster.yml down -v",
    "cluster:init": "ts-node scripts/cluster/init.ts",
    "test:cluster": "vitest run tests/integration/cluster",
    "docker:test": "docker compose -f docker/compose/docker-compose.test.yml up --build --abort-on-container-exit",
    "docker:test:down": "docker compose -f docker/compose/docker-compose.test.yml down -v"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@aws-sdk/client-elasticache": "^3.1075.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.5.0",
    "ioredis": "^5.11.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "redis": "^6.0.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
